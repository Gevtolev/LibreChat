      preset: { endpoint: "openAI", model: "gpt-5.4-pro" }
    - name: "gpt-5.4-mini"
      label: "GPT-5.4 mini"
      group: "OpenAI"
      iconURL: "openAI"
      preset: { endpoint: "openAI", model: "gpt-5.4-mini" }
    - name: "gpt-5.4-nano"
