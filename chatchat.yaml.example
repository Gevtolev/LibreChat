# ChatChat Configuration
# Copy this file to `librechat.yaml` (or set CONFIG_PATH) and adjust values.
#
# 混合中转策略：
# - 走 OpenRouter（${OPENROUTER_KEY}, https://openrouter.ai/api/v1）：
#   xAI / Grok、DeepSeek、GLM、Kimi、MiniMax —— 这几家 OpenRouter 可直连。
# - 保留 gptsapi.net（${GPTSAPI_KEY}）：
#   内置 openAI / anthropic 端点经 .env 的 OPENAI_REVERSE_PROXY / ANTHROPIC_REVERSE_PROXY
#   指向 gptsapi；Gemini / Claude / GPT 的 custom 端点亦经 gptsapi。
#   （OpenAI / Google / Anthropic 三家在 OpenRouter 上被 provider ToS 拒绝，故不切。）
# - 内置 google 端点禁用（.env GOOGLE_KEY 留空），改用 name='Gemini' 的 custom 端点经 gptsapi 托管。
# 模型选择器由 modelSpecs 策展（enforce 锁定，只显策展卡）。
# anonymousAccess: true —— 未登录访客获得静默 GUEST 账号（3 条试用消息）。

version: 1.3.11

cache: true

# Anonymous visitors get a silent GUEST account (3-message trial)
anonymousAccess: true

# File storage: use S3-compatible (Cloudflare R2)
fileStrategy: "s3"

interface:
  endpointsMenu: false
  modelSelect: false
  parameters: true
  presets: false

memory:
  disabled: false
  personalize: true
  messageWindowSize: 5
  validKeys: ["preferences", "personal_info", "work_info", "skills", "interests", "context"]
  agent:
    enabled: true
    provider: "openAI"               # routed to gptsapi via OPENAI_REVERSE_PROXY
    model: "gpt-4o-mini"             # upstream's documented example model for the memory agent
    instructions: >
      Extract durable facts about the user worth remembering across chats:
      stated preferences (response format, tone, length), working context
      (languages, frameworks, projects, role), and stable personal facts.
      Only store facts the user stated about themselves. Never store the AI
      assistant's own replies, self-description, or disclaimers (e.g. "I am
      an AI/language model...") as if they were facts about the user.
      Do NOT store secrets, passwords, API keys, health, or financial details.
      Update/replace existing keys rather than duplicating.

registration:
  socialLogins:
    - google
    - github

endpoints:
  # OpenAI — GPT-5 family（经 .env OPENAI_REVERSE_PROXY 路由到 gptsapi）
  openAI:
    titleConvo: true
    titleModel: "gemini-2.5-flash-lite"   # 便宜模型做标题（经 gptsapi 可达）
    summarize: true
    summaryModel: "gemini-2.5-flash-lite"

  # Anthropic — Claude family（经 .env ANTHROPIC_REVERSE_PROXY 路由到 gptsapi）
  anthropic:
    titleConvo: true
    titleModel: "gemini-2.5-flash-lite"
    summarize: true
    summaryModel: "gemini-2.5-flash-lite"

  # Custom endpoints — 全部经 gptsapi（OpenAI 兼容），单 ${GPTSAPI_KEY}
  custom:
    # Google — Gemini family
    - name: "Gemini"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default:
          - "gemini-3.1-pro-preview"
          - "gemini-3-flash-preview"
          - "gemini-2.5-flash"
          - "gemini-2.5-flash-lite"
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "Gemini"
      iconURL: "google"
      dropParams: ["stop"]

    # Anthropic — Claude family (OpenAI-compatible via gptsapi; native Messages API path 404s through the relay)
    - name: "Claude"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default:
          - "claude-opus-4-8"
          - "claude-opus-4-7"
          - "claude-opus-4-6"
          - "claude-opus-4-5-20251101"
          - "claude-sonnet-4-6"
          - "claude-sonnet-4-6-thinking"
          - "claude-haiku-4-5-20251001"
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "Claude"
      iconURL: "anthropic"
      dropParams: ["stop"]

    # xAI — Grok family
    - name: "xAI"
      apiKey: "${OPENROUTER_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default:
          - "x-ai/grok-4.5"
          - "x-ai/grok-4.3"
          - "x-ai/grok-4.20"
          - "x-ai/grok-4.20-multi-agent"
        fetch: false
      titleConvo: true
      titleModel: "x-ai/grok-4.3"
      modelDisplayLabel: "xAI"
      iconURL: "xai"
      dropParams: ["stop"]

    # DeepSeek
    - name: "DeepSeek"
      apiKey: "${OPENROUTER_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default: ["deepseek/deepseek-v4-pro", "deepseek/deepseek-v4-flash"]
        fetch: false
      titleConvo: true
      titleModel: "deepseek/deepseek-v4-flash"
      modelDisplayLabel: "DeepSeek"
      dropParams: ["stop"]

    # GLM (Zhipu)
    - name: "GLM"
      apiKey: "${OPENROUTER_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default: ["z-ai/glm-5.2", "z-ai/glm-5-turbo"]
        fetch: false
      titleConvo: true
      titleModel: "z-ai/glm-5-turbo"
      modelDisplayLabel: "GLM"
      dropParams: ["stop"]

    # Kimi (Moonshot)
    - name: "Kimi"
      apiKey: "${OPENROUTER_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default: ["moonshotai/kimi-k2.6"]
        fetch: false
      titleConvo: true
      titleModel: "moonshotai/kimi-k2.6"
      modelDisplayLabel: "Kimi"
      dropParams: ["stop"]

    # MiniMax
    - name: "MiniMax"
      apiKey: "${OPENROUTER_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default: ["minimax/minimax-m3"]
        fetch: false
      titleConvo: true
      titleModel: "minimax/minimax-m3"
      modelDisplayLabel: "MiniMax"
      dropParams: ["stop"]

# Curated model cards (use.ai-style). enforce: only these show in the selector.
modelSpecs:
  enforce: true
  prioritize: true
  list:
    # ---- Gemini ----
    - name: "gemini-2.5-flash"
      label: "Gemini 2.5 Flash"
      group: "Gemini"
      iconURL: "google"
      description: "Fast & efficient"
      preset: { endpoint: "Gemini", model: "gemini-2.5-flash" }
    - name: "gemini-3.1-pro-preview"
      label: "Gemini 3.1 Pro"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-3.1-pro-preview" }
    - name: "gemini-3-flash-preview"
      label: "Gemini 3 Flash"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-3-flash-preview" }
    - name: "gemini-2.5-flash-lite"
      label: "Gemini 2.5 Flash Lite"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-2.5-flash-lite" }
    # ---- OpenAI ----
    - name: "gpt-5.5"
      label: "GPT-5.5"
      group: "OpenAI"
      iconURL: "openAI"
      preset: { endpoint: "openAI", model: "gpt-5.5" }
    - name: "gpt-5.4"
